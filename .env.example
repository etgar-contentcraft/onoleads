# =============================================================================
# OnoLeads Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Supabase (required) ---
# Public URL and anonymous key are exposed to the client (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct database connection string - server-side only
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# --- Webhook Security (optional) ---
# HMAC secret for signing webhook payloads to Make.com or other integrations
WEBHOOK_SECRET=your-webhook-secret-here

# --- Application Settings ---
# NODE_ENV is set automatically by Next.js (development/production)
# In production, secure cookies and HSTS are enforced automatically

# Site URL - used for auth redirect links (invitations, password reset)
# Defaults to https://onoleads.vercel.app if not set
NEXT_PUBLIC_SITE_URL=https://onoleads.vercel.app
